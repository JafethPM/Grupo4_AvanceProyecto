@{
    ViewData["Title"] = "Login";
}

<form asp-action="Login" method="post" class="p-4">

    <h2>Login</h2>

    <div class="mb-3">
        <input type="email"
               name="email"
               class="form-control"
               placeholder="Correo"
               required />
    </div>

    <div class="mb-3">
        <input type="password"
               name="password"
               class="form-control"
               placeholder="Contraseña"
               required />
    </div>

    <button type="submit" class="btn btn-primary w-100">
        Ingresar
    </button>

    @if (ViewBag.Error != null)
    {
        <p class="text-danger mt-3">@ViewBag.Error</p>
    }

</form>

