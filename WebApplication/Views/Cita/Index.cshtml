@model List<WebApplicationAPP.Models.Servicio>

<h2>Servicios</h2>

<table class="table">
    <tr>
        <th>Nombre</th>
        <th>Especialista</th>
        <th>Monto</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Nombre</td>
            <td>@item.Especialista</td>
            <td>@item.Monto</td>
            <td>
                <a asp-action="Reservar" asp-route-id="@item.Id" class="btn btn-primary">
                    Reservar
                </a>
            </td>
        </tr>
    }
</table>
